{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/downloads/keyboard-wtf-setup.exe",
      "destination": "https://github.com/UnknownGod2011/keyboard.wtf/releases/download/v1.2.0/keyboard-wtf-setup.exe",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/downloads/(.*)",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ]
}
